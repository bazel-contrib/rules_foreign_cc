workspace(name = "rules_foreign_cc_detect_root_test")

# We do not initialize rules_foreign_cc, because we only need to access
# detect_root.bzl file from them.
local_repository(
    name = "rules_foreign_cc",
    path = "../..",
)

load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "bazel_lib",
    sha256 = "e733937de2f542436c5d3d618e22c638489b40dfd251284050357babe71103d7",
    strip_prefix = "bazel-lib-3.2.0",
    url = "https://github.com/bazel-contrib/bazel-lib/releases/download/v3.2.0/bazel-lib-v3.2.0.tar.gz",
)

load("@bazel_lib//lib:repositories.bzl", "bazel_lib_dependencies")

# Required bazel-lib dependencies

bazel_lib_dependencies()

new_local_repository(
    name = "rules_foreign_cc_detect_root_test_repo",
    build_file_content = """\
filegroup(
    name = "srcs",
    srcs = glob(["**/**"]),
    visibility = ["//visibility:public"],
)
""",
    path = "dir1",
)

http_archive(
    name = "bazel_ci_rules",
    sha256 = "eca21884e6f66a88c358e580fd67a6b148d30ab57b1680f62a96c00f9bc6a07e",
    strip_prefix = "bazelci_rules-1.0.0",
    url = "https://github.com/bazelbuild/continuous-integration/releases/download/rules-1.0.0/bazelci_rules-1.0.0.tar.gz",
)

load("@bazel_ci_rules//:rbe_repo.bzl", "rbe_preconfig")

# Creates a default toolchain config for RBE.
# Use this as is if you are using the rbe_ubuntu16_04 container,
# otherwise refer to RBE docs.
rbe_preconfig(
    name = "buildkite_config",
    toolchain = "ubuntu2204",
)
