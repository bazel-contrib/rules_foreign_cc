cc_binary(
    name = "foreign_duplicate_static_binary",
    srcs = ["main.c"],
    dynamic_deps = [
        ":foreign_demo_c",
        ":foreign_demo_d",
    ],
    tags = ["manual"],
)

cc_binary(
    name = "foreign_repeatable_binary",
    srcs = ["main.c"],
    dynamic_deps = [
        ":foreign_repeatable_a",
        ":foreign_repeatable_b",
    ],
)

cc_library(name = "foreign_demo_c_owner")

cc_library(name = "foreign_demo_d_owner")

expect_failure_test(
    name = "native_duplicate_export_shared_test",
    failure_message = "Two shared libraries in dependencies export the same symbols",
    target = ":native_duplicate_export_shared",
)

expect_failure_test(
    name = "native_duplicate_static_binary_test",
    failure_message = "Two shared libraries in dependencies link the same",
    target = ":native_duplicate_static_binary",
)

expect_failure_test(
    name = "foreign_duplicate_export_binary_test",
    failure_message = "Two shared libraries in dependencies export the same symbols",
    target = ":foreign_duplicate_export_binary",
)

expect_failure_test(
    name = "foreign_duplicate_static_binary_test",
    failure_message = "Two shared libraries in dependencies link the same",
    target = ":foreign_duplicate_static_binary",
)

analysis_smoke_test(
    name = "native_repeatable_binary_test",
    target = ":native_repeatable_binary",
)

analysis_smoke_test(
    name = "foreign_repeatable_binary_test",
    target = ":foreign_repeatable_binary",
)
