load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_import", "cc_library")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//foreign_cc:defs.bzl", "cmake", "foreign_cc_static_library")
load(":tests.bzl", "foreign_cc_static_library_default_test")

package(default_visibility = ["//visibility:public"])

config_setting(
    name = "macos",
    constraint_values = ["@platforms//os:macos"],
)

config_setting(
    name = "windows",
    constraint_values = ["@platforms//os:windows"],
)

filegroup(
    name = "srcs",
    srcs = ["CMakeLists.txt"] + glob([
        "include/**",
        "src/**",
    ]),
)

cc_library(
    name = "dep_1",
    linkopts = [
        "dep_1_arg_1",
        "dep_1_arg_2",
        "dep_1_arg_1",
    ],
)

cc_library(
    name = "duplicate_linkopts",
    linkopts = [
        "linkopts_only_arg_1",
        "linkopts_only_arg_2",
        "linkopts_only_arg_1",
    ],
)

cc_library(
    name = "linkopts_only",
    linkopts = [
        "linkopts_only_arg_1",
        "linkopts_only_arg_2",
        "linkopts_only_arg_1",
    ],
    deps = [":duplicate_linkopts"],
)

cmake(
    name = "combo_raw",
    generate_crosstool_file = False,
    lib_source = ":srcs",
    out_include_dir = "include",
    out_interface_libs = select({
        ":windows": ["combo_shared.lib"],
        "//conditions:default": [],
    }),
    out_shared_libs = select({
        ":macos": ["libcombo_shared.dylib"],
        ":windows": ["combo_shared.dll"],
        "//conditions:default": ["libcombo_shared.so"],
    }),
    out_static_libs = select({
        ":windows": ["combo.lib"],
        "//conditions:default": ["libcombo.a"],
    }),
    deps = [
        ":dep_1",
        ":linkopts_only",
        "//test/facade_library:demo_cc_import_control",
    ],
)

foreign_cc_static_library(
    name = "combo_foreign_static",
    src = ":combo_raw",
)

cc_import(
    name = "combo_foreign_import",
    hdrs = ["include/combo.h"],
    static_library = ":combo_foreign_static",
)

cc_binary(
    name = "combo_foreign_consumer",
    srcs = ["src/main.c"],
    includes = ["include"],
    deps = [":combo_foreign_import"],
)

filegroup(
    name = "combo_foreign_linkdeps",
    srcs = [":combo_foreign_static"],
    output_group = "linkdeps",
)

filegroup(
    name = "combo_foreign_linkopts",
    srcs = [":combo_foreign_static"],
    output_group = "linkopts",
)

foreign_cc_static_library_default_test(
    name = "combo_foreign_default_test",
    size = "small",
    expected_default_files = select({
        ":windows": ["combo_foreign_static.lib"],
        "//conditions:default": ["libcombo_foreign_static.a"],
    }),
    expected_linkdeps_file = "combo_foreign_static_linkdeps.txt",
    expected_linkopts_file = "combo_foreign_static_linkopts.txt",
    expected_runfiles = select({
        ":macos": ["libdemo.dylib"],
        ":windows": ["demo.dll"],
        "//conditions:default": ["libdemo.so"],
    }),
    target_under_test = ":combo_foreign_static",
)

sh_test(
    name = "combo_foreign_linkdeps_content_test",
    size = "small",
    srcs = ["check_text_file.sh"],
    args = [
        "$(location :combo_foreign_linkdeps)",
        "$(location :expected_linkdeps.txt)",
    ],
    data = [
        ":combo_foreign_linkdeps",
        ":expected_linkdeps.txt",
    ],
    target_compatible_with = select({
        ":windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

sh_test(
    name = "combo_foreign_linkopts_content_test",
    size = "small",
    srcs = ["check_text_file.sh"],
    args = [
        "$(location :combo_foreign_linkopts)",
        "$(location :expected_linkopts.txt)",
    ],
    data = [
        ":combo_foreign_linkopts",
        ":expected_linkopts.txt",
    ],
    target_compatible_with = select({
        ":windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)
