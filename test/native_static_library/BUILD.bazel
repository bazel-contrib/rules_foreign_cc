load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:defs.bzl", "cc_import", "cc_library")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//test/facade_shared_library:tests.bzl", "runfiles_presence_test")
load(":native_static_library_macro.bzl", "cc_static_library")
load(":tests.bzl", "native_cc_static_library_default_test")

package(default_visibility = ["//visibility:public"])

config_setting(
    name = "windows",
    constraint_values = ["@platforms//os:windows"],
)

cc_library(
    name = "leaf_obj",
    srcs = ["src/leaf.c"],
    hdrs = ["include/leaf.h"],
    includes = ["include"],
)

cc_library(
    name = "mid_obj",
    srcs = ["src/mid.c"],
    hdrs = ["include/mid.h"],
    includes = ["include"],
    deps = [":leaf_obj"],
)

cc_library(
    name = "combo_obj",
    srcs = ["src/combo.c"],
    hdrs = ["include/combo.h"],
    includes = ["include"],
)

cc_library(
    name = "duplicate_linkopts",
    linkopts = [
        "linkopts_only_arg_1",
        "linkopts_only_arg_2",
        "linkopts_only_arg_1",
    ],
)

cc_library(
    name = "linkopts_only",
    linkopts = [
        "linkopts_only_arg_1",
        "linkopts_only_arg_2",
        "linkopts_only_arg_1",
    ],
    deps = [":duplicate_linkopts"],
)

cc_library(
    name = "late_linkopts",
    linkopts = ["late_dep_arg"],
)

cc_import(
    name = "prebuilt_dep",
    hdrs = ["include/prebuilt.h"],
    interface_library = select({
        ":windows": "//test/facade_library:demo_interface",
        "//conditions:default": None,
    }),
    shared_library = "//test/facade_library:demo_shared_dev",
    static_library = "//test/facade_library:demo_static",
)

cc_static_library(
    name = "combo_native_static",
    deps = [
        ":linkopts_only",
        ":mid_obj",
        ":prebuilt_dep",
    ],
)

cc_static_library(
    name = "combo_native_static_with_dep",
    deps = [
        ":late_linkopts",
        ":linkopts_only",
        ":mid_obj",
        ":prebuilt_dep",
    ],
)

cc_static_library(
    name = "combo_native_static_with_runfiles_dep",
    deps = [
        ":linkopts_only",
        ":mid_obj",
        ":prebuilt_dep",
        "//test/facade_static_library:runfiles_dep",
    ],
)

cc_static_library(
    name = "combo_native_consumer_static",
    deps = [
        ":combo_obj",
        "//test/facade_library:demo_cc_import_control",
        "//test/facade_static_library:dep_1",
        "//test/facade_static_library:linkopts_only",
    ],
)

filegroup(
    name = "combo_native_linkdeps",
    srcs = [":combo_native_static"],
    output_group = "linkdeps",
)

filegroup(
    name = "combo_native_linkopts",
    srcs = [":combo_native_static"],
    output_group = "linkopts",
)

filegroup(
    name = "combo_native_with_dep_linkopts",
    srcs = [":combo_native_static_with_dep"],
    output_group = "linkopts",
)

cc_import(
    name = "combo_native_import",
    hdrs = ["include/combo.h"],
    static_library = ":combo_native_consumer_static",
)

cc_binary(
    name = "combo_native_consumer",
    srcs = ["src/combo_main.c"],
    includes = ["include"],
    deps = [":combo_native_import"],
)

native_cc_static_library_default_test(
    name = "combo_native_default_test",
    size = "small",
    expect_validation_output_group = select({
        ":windows": False,
        "//conditions:default": True,
    }),
    expected_default_files = select({
        ":windows": ["combo_native_static.lib"],
        "//conditions:default": ["libcombo_native_static.a"],
    }),
    expected_linkdeps_file = "combo_native_static_linkdeps.txt",
    expected_linkopts_file = "combo_native_static_linkopts.txt",
    expected_runfiles = [],
    target_under_test = ":combo_native_static",
)

native_cc_static_library_default_test(
    name = "combo_native_with_runfiles_dep_test",
    size = "small",
    expect_validation_output_group = select({
        ":windows": False,
        "//conditions:default": True,
    }),
    expected_default_files = select({
        ":windows": ["combo_native_static_with_runfiles_dep.lib"],
        "//conditions:default": ["libcombo_native_static_with_runfiles_dep.a"],
    }),
    expected_linkdeps_file = "combo_native_static_with_runfiles_dep_linkdeps.txt",
    expected_linkopts_file = "combo_native_static_with_runfiles_dep_linkopts.txt",
    expected_runfiles = ["runtime_note.txt"],
    target_under_test = ":combo_native_static_with_runfiles_dep",
)

sh_test(
    name = "combo_native_linkdeps_content_test",
    size = "small",
    srcs = ["check_text_file.sh"],
    args = [
        "$(location :combo_native_linkdeps)",
        "$(location :expected_linkdeps.txt)",
    ],
    data = [
        ":combo_native_linkdeps",
        ":expected_linkdeps.txt",
    ],
    target_compatible_with = select({
        ":windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

sh_test(
    name = "combo_native_linkopts_content_test",
    size = "small",
    srcs = ["check_text_file.sh"],
    args = [
        "$(location :combo_native_linkopts)",
        "$(location :expected_linkopts.txt)",
    ],
    data = [
        ":combo_native_linkopts",
        ":expected_linkopts.txt",
    ],
    target_compatible_with = select({
        ":windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

sh_test(
    name = "combo_native_with_dep_linkopts_content_test",
    size = "small",
    srcs = ["check_text_file.sh"],
    args = [
        "$(location :combo_native_with_dep_linkopts)",
        "$(location :expected_linkopts_with_dep.txt)",
    ],
    data = [
        ":combo_native_with_dep_linkopts",
        ":expected_linkopts_with_dep.txt",
    ],
    target_compatible_with = select({
        ":windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

runfiles_presence_test(
    name = "combo_native_consumer_runfiles_test",
    forbidden_basenames = select({
        ":windows": ["demo.dll"],
        "//conditions:default": ["libdemo.so"],
    }),
    required_basenames = [],
    target_under_test = ":combo_native_consumer",
)
