load(":env_test_cmake.bzl", "env_test_cmake")
load(":env_test_configure_make.bzl", "env_test_configure_make")
load(":env_test_make.bzl", "env_test_make")
load(":env_test_ninja.bzl", "env_test_ninja")

package(default_visibility = ["//test:__subpackages__"])

env_test_make(
    name = "make_default",
    check_makevars = {
        "MAKEFLAGS": " -- PREFIX={{INSTALLDIR}}",
    },
)

env_test_make(
    name = "make_tiny",
    check_makevars = {
        "MAKEFLAGS": " -j1 -- PREFIX={{INSTALLDIR}}",
    },
    make_attrs = {
        "resource_size": "tiny",
    },
)

env_test_ninja(
    name = "ninja_default",
    check_shellvars = {
        "NINJA_JOBS": "",
    },
)

env_test_ninja(
    name = "ninja_tiny",
    check_shellvars = {
        "NINJA_JOBS": "1",
    },
    ninja_attrs = {
        "resource_size": "tiny",
    },
)

env_test_cmake(
    name = "cmake_default",
    check_cmakevars = {
        "CMAKE_MINIMUM_REQUIRED_VERSION": "3.12",
        "CMAKE_SOURCE_DIR": "{{CMAKE_SOURCE_DIR}}",
    },
    check_shellvars = {
        "CMAKEVARS_FILE": "{{INSTALLDIR}}/cmakevars.out",
        "CMAKE_BUILD_PARALLEL_LEVEL": "",
    },
)

env_test_cmake(
    name = "cmake_tiny",
    check_cmakevars = {
        "CMAKE_MINIMUM_REQUIRED_VERSION": "3.12",
        "CMAKE_SOURCE_DIR": "{{CMAKE_SOURCE_DIR}}",
    },
    check_shellvars = {
        "CMAKEVARS_FILE": "{{INSTALLDIR}}/cmakevars.out",
        "CMAKE_BUILD_PARALLEL_LEVEL": "1",
    },
    cmake_attrs = {
        "resource_size": "tiny",
    },
)

env_test_configure_make(
    name = "configure_make_default",
    check_makevars = {
        "INSTALLDIR": "{{INSTALLDIR}}",
        "MAKEFLAGS": "",
        "abs_builddir": "{{abs_builddir}}",
        "abs_srcdir": "{{abs_srcdir}}",
    },
    check_shellvars = {
        "INSTALLDIR": "{{INSTALLDIR}}",
        "MAKEFLAGS": "",
    },
)

env_test_configure_make(
    name = "configure_make_tiny",
    check_makevars = {
        "INSTALLDIR": "{{INSTALLDIR}}",
        "MAKEFLAGS": " -j1",
        "abs_builddir": "{{abs_builddir}}",
        "abs_srcdir": "{{abs_srcdir}}",
    },
    check_shellvars = {
        "INSTALLDIR": "{{INSTALLDIR}}",
        "MAKEFLAGS": " -j1",
    },
    configure_make_attrs = {
        "resource_size": "tiny",
    },
)
