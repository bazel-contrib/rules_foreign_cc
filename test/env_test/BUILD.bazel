load(":env_test_cmake.bzl", "env_test_cmake")
load(":env_test_configure_make.bzl", "env_test_configure_make")
load(":env_test_make.bzl", "env_test_make")
load(":env_test_meson.bzl", "env_test_meson")
load(":env_test_ninja.bzl", "env_test_ninja")

package(default_visibility = ["//test:__subpackages__"])

# Regen-tool stubs that configure_make injects into the configure environment
# to neutralize automake's regeneration recipes. The five vars below are the
# subset that Makefile.in.tmpl exposes via @VAR@ substitution; AUTOM4TE and
# HELP2MAN are also stubbed in configure.bzl but aren't surfaced in the test
# Makefile.
_REGEN_STUB_MAKEVARS = {
    "ACLOCAL": "true",
    "AUTOCONF": "true",
    "AUTOHEADER": "true",
    "AUTOMAKE": "true",
    "MAKEINFO": "true",
}

# The stubs are emitted only as a prefix on the ./configure command line; they
# must not leak into the global build environment, so the shell-side check
# expects them empty.
_REGEN_STUB_SHELLVARS_UNSET = {k: "" for k in _REGEN_STUB_MAKEVARS}

_NOT_WINDOWS = select({
    "@platforms//os:windows": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

STANDARD_VARS = {
    "BUILD_TMPDIR": "{{BUILD_TMPDIR}}",
    "EXT_BUILD_DEPS": "{{EXT_BUILD_DEPS}}",
    "EXT_BUILD_ROOT": "{{EXT_BUILD_ROOT}}",
    "INSTALLDIR": "{{INSTALLDIR}}",
}

env_test_make(
    name = "make_default",
    check_makevars = STANDARD_VARS | {
        # Note that we set GNUMAKEFLAGS, but make itself will convert it into
        # MAKEFLAGS, so we'll just see MAKEFLAGS set here
        "GNUMAKEFLAGS": "",
        "MAKEFLAGS": " -- PREFIX={{INSTALLDIR}}",
    },
)

env_test_make(
    name = "make_tiny",
    check_makevars = STANDARD_VARS | {
        # Note that we set GNUMAKEFLAGS, but make itself will convert it into
        # MAKEFLAGS, so we'll just see MAKEFLAGS set here
        "GNUMAKEFLAGS": "",
        "MAKEFLAGS": " -j3 --jobserver-auth={{JOBSERVER}} -- PREFIX={{INSTALLDIR}}",
    },
    make_attrs = {
        "resource_size": "tiny",
    },
)

env_test_make(
    name = "make_serial",
    check_makevars = STANDARD_VARS | {
        "GNUMAKEFLAGS": "",
        "MAKEFLAGS": " -j1 -- PREFIX={{INSTALLDIR}}",
    },
    make_attrs = {
        "resource_size": "serial",
    },
)

env_test_ninja(
    name = "ninja_default",
    check_shellvars = STANDARD_VARS | {
        "NINJA_JOBS": "",
    },
)

env_test_ninja(
    name = "ninja_tiny",
    check_shellvars = STANDARD_VARS | {
        "NINJA_JOBS": "3",
    },
    ninja_attrs = {
        "resource_size": "tiny",
    },
)

env_test_meson(
    name = "meson_default",
    check_shellvars = STANDARD_VARS | {
        "MESON_NUM_PROCESSES": "",
        "NINJA_JOBS": "",
    },
)

env_test_meson(
    name = "meson_tiny",
    check_shellvars = STANDARD_VARS | {
        "MESON_NUM_PROCESSES": "3",
        "NINJA_JOBS": "3",
    },
    meson_attrs = {
        "resource_size": "tiny",
    },
)

CMAKE_STANDARD_CVARS = {
    # none of the standard vars are cmake vars, so verify they aren't set
    k: ""
    for k in STANDARD_VARS.keys()
}

env_test_cmake(
    name = "cmake_default",
    check_cmakevars = CMAKE_STANDARD_CVARS | {
        "CMAKE_MINIMUM_REQUIRED_VERSION": "3.12",
        "CMAKE_SOURCE_DIR": "{{CMAKE_SOURCE_DIR}}",
    },
    check_shellvars = STANDARD_VARS | {
        # since we replace the binary dir, this overrides the STANDARD_VARS
        "BUILD_TMPDIR": "{{CMAKE_BINARY_DIR}}",
        "CMAKEVARS_FILE": "{{INSTALLDIR}}/cmakevars.out",
        "CMAKE_BUILD_PARALLEL_LEVEL": "",
        "GNUMAKEFLAGS": "",
        "MAKEFLAGS": "",
        "NINJA_JOBS": "",
    },
)

env_test_cmake(
    name = "cmake_tiny",
    check_cmakevars = CMAKE_STANDARD_CVARS | {
        "CMAKE_MINIMUM_REQUIRED_VERSION": "3.12",
        "CMAKE_SOURCE_DIR": "{{CMAKE_SOURCE_DIR}}",
    },
    check_shellvars = {
        # since we replace the binary dir, this overrides the STANDARD_VARS
        "BUILD_TMPDIR": "{{CMAKE_BINARY_DIR}}",
        "CMAKEVARS_FILE": "{{INSTALLDIR}}/cmakevars.out",
        "CMAKE_BUILD_PARALLEL_LEVEL": "3",
        # Note that we set GNUMAKEFLAGS, but make itself will convert it into
        # MAKEFLAGS, so for the cmake test we won't see it converted yet.
        "GNUMAKEFLAGS": "-j3",
        "MAKEFLAGS": "",
        "NINJA_JOBS": "3",
    },
    cmake_attrs = {
        "resource_size": "tiny",
    },
)

env_test_configure_make(
    name = "configure_make_default",
    check_makevars = STANDARD_VARS | _REGEN_STUB_MAKEVARS | {
        # since we replace the builddir, this overrides the STANDARD_VARS
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "MAKEFLAGS": "",
        "abs_builddir": "{{abs_builddir}}",
        "abs_srcdir": "{{abs_srcdir}}",
    },
    check_shellvars = STANDARD_VARS | _REGEN_STUB_SHELLVARS_UNSET | {
        # since we replace the builddir, this overrides the STANDARD_VARS
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "MAKEFLAGS": "",
    },
    # srcdir ends up being C:/..., and then autotools looks for the aux files
    # using $srcdir$PATH_SEPARATOR$srcdir/.. and PATH_SEPARATOR is :, so the :
    # in the path breaks it.
    configure_make_attrs = {
        "target_compatible_with": _NOT_WINDOWS,
    },
)

# User-supplied env values override the defaults for regen tools (test that
# the stubs don't blindly clobber a real path the user wants).
env_test_configure_make(
    name = "configure_make_user_override",
    check_makevars = STANDARD_VARS | _REGEN_STUB_MAKEVARS | {
        "ACLOCAL": "/usr/bin/aclocal-1.17",
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "MAKEFLAGS": "",
        "abs_builddir": "{{abs_builddir}}",
        "abs_srcdir": "{{abs_srcdir}}",
    },
    check_shellvars = STANDARD_VARS | _REGEN_STUB_SHELLVARS_UNSET | {
        # User env IS exported globally by framework.bzl's prelude, so unlike
        # the synthetic stubs the user-supplied ACLOCAL appears in the shell.
        "ACLOCAL": "/usr/bin/aclocal-1.17",
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "MAKEFLAGS": "",
    },
    configure_make_attrs = {
        "env": {"ACLOCAL": "/usr/bin/aclocal-1.17"},
        "target_compatible_with": _NOT_WINDOWS,
    },
)

# Tools listed in unstubbed_regen_tools fall back to configure's autodetected
# default. For this fixture configure resolves ACLOCAL via automake's
# `am_missing_run` helper.
env_test_configure_make(
    name = "configure_make_unstubbed",
    check_makevars = STANDARD_VARS | _REGEN_STUB_MAKEVARS | {
        # The shell configure auto-detects for `am_missing_run` is platform-
        # dependent (/bin/bash on Linux, /bin/sh on macOS). Makefile.in.tmpl's
        # sed pipeline normalizes it to `{{SHELL}}` so the assertion matches
        # on both.
        "ACLOCAL": "{{SHELL}} '{{abs_srcdir}}/missing' aclocal-1.16",
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "MAKEFLAGS": "",
        "abs_builddir": "{{abs_builddir}}",
        "abs_srcdir": "{{abs_srcdir}}",
    },
    check_shellvars = STANDARD_VARS | _REGEN_STUB_SHELLVARS_UNSET | {
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "MAKEFLAGS": "",
    },
    configure_make_attrs = {
        "target_compatible_with": _NOT_WINDOWS,
        "unstubbed_regen_tools": ["ACLOCAL"],
    },
)

env_test_configure_make(
    name = "configure_make_tiny",
    check_makevars = STANDARD_VARS | {
        # since we replace the builddir, this overrides the STANDARD_VARS
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "INSTALLDIR": "{{INSTALLDIR}}",
        "MAKEFLAGS": " -j3 --jobserver-auth={{JOBSERVER}}",
        "abs_builddir": "{{abs_builddir}}",
        "abs_srcdir": "{{abs_srcdir}}",
    },
    check_shellvars = STANDARD_VARS | {
        # since we replace the builddir, this overrides the STANDARD_VARS
        "BUILD_TMPDIR": "{{abs_builddir}}",
        "INSTALLDIR": "{{INSTALLDIR}}",
        "MAKEFLAGS": " -j3 --jobserver-auth={{JOBSERVER}}",
    },
    configure_make_attrs = {
        "resource_size": "tiny",
        "target_compatible_with": _NOT_WINDOWS,
    },
)
