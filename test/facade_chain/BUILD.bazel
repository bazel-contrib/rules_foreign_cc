package(default_visibility = ["//visibility:public"])

config_setting(
    name = "macos",
    constraint_values = ["@platforms//os:macos"],
)

config_setting(
    name = "windows",
    constraint_values = ["@platforms//os:windows"],
)

filegroup(
    name = "leaf_srcs",
    srcs = ["leaf_proj/CMakeLists.txt"] + [
        "include/leaf.h",
        "src/leaf.c",
    ],
)

filegroup(
    name = "mid_srcs",
    srcs = ["mid_proj/CMakeLists.txt"] + [
        "include/leaf.h",
        "include/mid.h",
        "src/mid.c",
    ],
)

filegroup(
    name = "top_srcs",
    srcs = ["top_proj/CMakeLists.txt"] + [
        "include/mid.h",
        "include/top.h",
        "src/top.c",
    ],
)

cmake(
    name = "leaf_raw",
    generate_crosstool_file = False,
    lib_source = ":leaf_srcs",
    out_include_dir = "include",
    out_interface_libs = select({
        ":windows": ["leaf.lib"],
        "//conditions:default": [],
    }),
    out_shared_libs = select({
        ":macos": ["libleaf.dylib"],
        ":windows": ["leaf.dll"],
        "//conditions:default": ["libleaf.so"],
    }),
    out_static_libs = select({
        ":windows": ["leaf_static.lib"],
        "//conditions:default": ["libleaf.a"],
    }),
)

select_foreign_output(
    name = "leaf_shared",
    src = ":leaf_raw",
    basename = select({
        ":macos": "libleaf.dylib",
        ":windows": "leaf.dll",
        "//conditions:default": "libleaf.so",
    }),
)

select_foreign_output(
    name = "leaf_static",
    src = ":leaf_raw",
    basename = select({
        ":windows": "leaf_static.lib",
        "//conditions:default": "libleaf.a",
    }),
)

select_foreign_output(
    name = "leaf_interface",
    src = ":leaf_raw",
    basename = "leaf.lib",
    target_compatible_with = select({
        ":windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
)

cc_import(
    name = "leaf_import",
    hdrs = ["include/leaf.h"],
