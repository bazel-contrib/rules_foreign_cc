package(default_visibility = ["//visibility:public"])

config_setting(
    name = "macos",
    constraint_values = ["@platforms//os:macos"],
)

config_setting(
    name = "windows",
    constraint_values = ["@platforms//os:windows"],
)

filegroup(
    name = "srcs",
    srcs = ["CMakeLists.txt"] + glob([
        "include/**",
        "src/**",
    ]),
)

cc_library(
    name = "native_demo",
    srcs = ["src/demo.c"],
    hdrs = ["include/demo.h"],
    includes = ["include"],
    linkstatic = False,
    local_defines = select({
        ":windows": ["DEMO_SHARED_EXPORTS"],
        "//conditions:default": [],
    }),
)

cmake(
    name = "demo_raw",
    generate_crosstool_file = False,
    lib_source = ":srcs",
    out_include_dir = "include",
    out_interface_libs = select({
        ":windows": ["demo.lib"],
        "//conditions:default": [],
    }),
    out_shared_libs = select({
        ":macos": [
            "libdemo.dylib",
            "libdemo.1.dylib",
            "libdemo.1.2.3.dylib",
        ],
        ":windows": ["demo.dll"],
        "//conditions:default": [
            "libdemo.so",
            "libdemo.so.1",
            "libdemo.so.1.2.3",
        ],
    }),
    out_static_libs = select({
        ":windows": ["demo_static.lib"],
        "//conditions:default": ["libdemo.a"],
    }),
)

select_foreign_output(
    name = "demo_shared_dev",
    src = ":demo_raw",
    basename = select({
        ":macos": "libdemo.dylib",
        ":windows": "demo.dll",
        "//conditions:default": "libdemo.so",
    }),
)

select_foreign_output(
    name = "demo_static",
    src = ":demo_raw",
    basename = select({
        ":windows": "demo_static.lib",
        "//conditions:default": "libdemo.a",
    }),
)

select_foreign_output(
    name = "demo_interface",
    src = ":demo_raw",
    basename = "demo.lib",
    target_compatible_with = select({
        ":windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
)

cc_import(
    name = "demo_cc_import_control",
    hdrs = ["include/demo.h"],
