all: simple

.PHONY: all

simple: $(OUTPUT)

.PHONY: simple

$(OUTPUT): ./src/simple.c
	$(CC) $(CPPFLAGS) -o $(OBJECT) -c ./src/simple.c -I./include -I.
	$(AR) $(LDFLAGS)

install: $(OUTPUT)
	mkdir -p simple
	mkdir -p simple/lib
	cp -p $(OUTPUT) ./simple/lib/$(OUTPUT)
	cp -rp ./include ./simple

clean:
	rm -rf simple

.PHONY: clean

test: all

.PHONY: test
