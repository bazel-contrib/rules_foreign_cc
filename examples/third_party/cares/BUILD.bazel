load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("@build_bazel_rules_apple//apple:apple_binary.bzl", "apple_binary")
load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

cc_test(
    name = "test",
    size = "small",
    srcs = ["c-ares-test.cpp"],
    local_defines = select({
        "@platforms//os:windows": ["CARES_STATICLIB"],
        "//conditions:default": [],
    }),
    visibility = ["//:__pkg__"],
    deps = ["@cares"],
)

cc_library(
    name = "lib",
    srcs = ["c-ares-test.cpp"],
    local_defines = select({
        "@platforms//os:windows": ["CARES_STATICLIB"],
        "//conditions:default": [],
    }),
    deps = ["@cares"],
)

apple_binary(
    name = "ios_binary",
    minimum_os_version = "12.0",
    platform_type = "ios",
    tags = ["manual"],
    deps = [":lib"],
)

build_test(
    name = "test_ios",
    target_compatible_with = ["@platforms//os:macos"],
    targets = ["ios_binary"],
)

test_suite(
    name = "all_tests",
)
