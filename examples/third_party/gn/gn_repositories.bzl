"""A module defining the third party dependency gn"""

load("@bazel_tools//tools/build_defs/repo:git.bzl", "new_git_repository")
load("@bazel_tools//tools/build_defs/repo:utils.bzl", "maybe")

def gn_repositories():
    maybe(
        new_git_repository,
        name = "gn",
        build_file = Label("//gn:BUILD.gn.bazel"),
        commit = "281ba2c91861b10fec7407c4b6172ec3d4661243",
        patch_cmds = [
            "python build/gen.py --no-last-commit-position",
            "python -c \"open('out/last_commit_position.h', 'w').write('''// Generated by @rules_foreign_cc_examples_third_party//gn:generate_ninja.sh\\n\\n#ifndef OUT_LAST_COMMIT_POSITION_H_\\n#define OUT_LAST_COMMIT_POSITION_H_\\n\\n#define LAST_COMMIT_POSITION_NUM 1891\\n#define LAST_COMMIT_POSITION \\\"1891 (dfcbc6fe)\\\"\\n\\n#endif  // OUT_LAST_COMMIT_POSITION_H_\\n''')\"",
        ],
        patch_cmds_win = [
            "python.exe build/gen.py --no-last-commit-position",
            "@('// Generated by @rules_foreign_cc_examples_third_party//gn:generate_ninja.sh', '', '#ifndef OUT_LAST_COMMIT_POSITION_H_', '#define OUT_LAST_COMMIT_POSITION_H_', '', '#define LAST_COMMIT_POSITION_NUM 1891', '#define LAST_COMMIT_POSITION \"1891 (dfcbc6fe)\"', '', '#endif  // OUT_LAST_COMMIT_POSITION_H_') | Set-Content -Path 'out\\\\last_commit_position.h' -Encoding Ascii",
        ],
        remote = "https://gn.googlesource.com/gn",
        shallow_since = "1639743738 +0000",
    )
