load("@bazel_skylib//rules:build_test.bzl", "build_test")

alias(
    name = "pcre_build",
    actual = "@pcre//:pcre",
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

exports_files(
    [
        "BUILD.pcre.bazel",
    ],
    visibility = ["//visibility:public"],
)

build_test(
    name = "pcre_build_test",
    targets = [
        ":pcre_build",
    ],
    visibility = ["//:__pkg__"],
)

test_suite(
    name = "all_tests",
)
