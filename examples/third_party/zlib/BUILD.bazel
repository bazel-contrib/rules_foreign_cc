load("@rules_cc//cc:defs.bzl", "cc_binary")
load(":matrix_defs.bzl", "zlib_linkage_test")

exports_files(
    [
        "BUILD.zlib.bazel",
        "run_runnable_binary.sh",
        "verify_zlib_linkage.sh",
        "zlib-example.cpp",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "cmake_usage_srcs",
    srcs = [
        "CMakeLists.txt",
        "zlib-example.cpp",
    ],
    visibility = ["//visibility:public"],
)

# Keep one Bazel-native baseline in the root package so there is still a
# straightforward non-matrix example next to the source file.
cc_binary(
    name = "zlib_usage_example",
    srcs = ["zlib-example.cpp"],
    deps = ["@examples_zlib//:zlib"],
)

zlib_linkage_test(
    name = "test_zlib",
    data = [":zlib_usage_example"],
    expected_linkage = "static",
    inspect_target = ":zlib_usage_example",
)

test_suite(
    name = "all_tests",
    tests = [
        ":test_zlib",
        "//zlib/foreign_shared_cc_dynamic:test",
        "//zlib/foreign_shared_cmake:app_run_test",
        "//zlib/foreign_shared_cmake:app_test",
        "//zlib/foreign_static_cc_dynamic:test",
        "//zlib/foreign_static_cc_static:test",
        "//zlib/foreign_static_cmake:app_test",
        "//zlib/native_shared_cc_dynamic_deps:test",
        "//zlib/native_shared_cc_wrapped:test",
        "//zlib/native_shared_cmake_dynamic_deps:app_run_test",
        "//zlib/native_shared_cmake_dynamic_deps:app_test",
        "//zlib/native_shared_cmake_wrapped:app_test",
        "//zlib/native_static_cc_dynamic:test",
        "//zlib/native_static_cc_static:test",
        "//zlib/native_static_cmake:app_test",
    ],
)
