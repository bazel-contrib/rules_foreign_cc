load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake", "runnable_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

exports_files(
    [
        "BUILD.zlib.bazel",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "shared_usage_srcs",
    srcs = [
        "CMakeLists.txt",
        "zlib-example.cpp",
    ],
    visibility = ["//visibility:public"],
)

cc_binary(
    name = "zlib_usage_example",
    srcs = ["zlib-example.cpp"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@rules_foreign_cc_examples_third_party//:broken"],
        "//conditions:default": [],
    }),
    deps = ["@examples_zlib//:zlib"],
)

sh_test(
    name = "test_zlib",
    size = "small",
    srcs = ["test_zlib.sh"],
    data = [":zlib_usage_example"],
    visibility = ["//:__pkg__"],
)

cmake(
    name = "zlib_shared_usage_example",
    dynamic_deps = ["@examples_zlib//:zlib_shared"],
    lib_source = "shared_usage_srcs",
    out_binaries = ["zlib-example"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@rules_foreign_cc_examples_third_party//:broken"],
        "//conditions:default": [],
    }),
    deps = ["@examples_zlib//:zlib_static"],
)

runnable_binary(
    name = "run-zlib-example",
    binary = "zlib-example",
    foreign_cc_target = ":zlib_shared_usage_example",
)

sh_test(
    name = "test_shared_zlib",
    size = "small",
    srcs = ["test_shared_zlib.sh"],
    data = [":run-zlib-example"],
    visibility = ["//:__pkg__"],
)

test_suite(
    name = "all_tests",
)
