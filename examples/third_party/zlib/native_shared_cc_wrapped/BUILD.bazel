load("@rules_cc//cc:defs.bzl", "cc_binary")
load("//zlib:matrix_defs.bzl", "zlib_linkage_test")

# This matches the upstream rules_cc example shape: a normal cc_library wraps
# the shared library so consumers can depend on it like any other C++ target.
cc_binary(
    name = "bin",
    srcs = ["//zlib:zlib-example.cpp"],
    linkstatic = False,
    deps = ["@examples_zlib//:zlib_dynamic"],
)

zlib_linkage_test(
    name = "test",
    data = [":bin"],
    expected_linkage = "dynamic",
    inspect_target = ":bin",
)
