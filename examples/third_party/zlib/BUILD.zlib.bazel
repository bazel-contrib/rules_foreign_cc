load("@bazel_lib//lib:copy_file.bzl", "copy_file")
load("@bazel_lib//lib:directory_path.bzl", "directory_path")
load("@rules_cc//cc:defs.bzl", "cc_import", "cc_library", "cc_shared_library")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")

package(default_visibility = ["//visibility:public"])

ZLIB_PUBLIC_HDRS = [
    "zlib.h",
]

ZLIB_PRIVATE_HDRS = [
    "crc32.h",
    "deflate.h",
    "gzguts.h",
    "inffast.h",
    "inffixed.h",
    "inflate.h",
    "inftrees.h",
    "trees.h",
    "zutil.h",
]

ZLIB_SRCS = [
    "adler32.c",
    "compress.c",
    "crc32.c",
    "deflate.c",
    "gzclose.c",
    "gzlib.c",
    "gzread.c",
    "gzwrite.c",
    "infback.c",
    "inffast.c",
    "inflate.c",
    "inftrees.c",
    "trees.c",
    "uncompr.c",
    "zutil.c",
]

ZLIB_NATIVE_COPTS = select({
    "@platforms//os:windows": [],
    "//conditions:default": [
        "-Wno-deprecated-non-prototype",
        "-Wno-unused-variable",
        "-Wno-implicit-function-declaration",
    ],
})

CMAKE_COMMON = {
    "cache_entries": select({
        "@platforms//os:linux": {
            "CMAKE_C_FLAGS": "$${CMAKE_C_FLAGS:-} -fPIC",
        },
        "//conditions:default": {},
    }),
    "generate_args": select({
        "@platforms//os:windows": ["-GNinja"],
        "//conditions:default": [],
    }),
    "lib_source": ":all_srcs",
    "out_include_dir": "include",
}

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

# Foreign-built static zlib install tree
# providing headers plus the static archive.
cmake(
    name = "zlib",
    cache_entries = CMAKE_COMMON["cache_entries"],
    generate_args = CMAKE_COMMON["generate_args"],
    lib_source = CMAKE_COMMON["lib_source"],
    out_include_dir = CMAKE_COMMON["out_include_dir"],
    out_static_libs = select({
        "@platforms//os:windows": ["zlibstatic.lib"],
        "//conditions:default": ["libz.a"],
    }),
)

alias(
    name = "zlib_foreign_static",
    actual = ":zlib",
)

filegroup(
    name = "zlib_include_tree",
    srcs = [":zlib"],
    output_group = "include",
)

directory_path(
    name = "zlib_configured_zconf_h_path",
    directory = ":zlib_include_tree",
    path = "zconf.h",
)

copy_file(
    name = "zlib_configured_zconf_h",
    src = ":zlib_configured_zconf_h_path",
    out = "generated_include/zconf.h",
)

# Foreign-built shared zlib install tree
# providing headers plus the shared-library artifacts.
cmake(
    name = "zlib_foreign_shared",
    cache_entries = CMAKE_COMMON["cache_entries"] | {
        "BUILD_SHARED_LIBS": "ON",
    },
    generate_args = CMAKE_COMMON["generate_args"],
    lib_source = CMAKE_COMMON["lib_source"],
    out_include_dir = CMAKE_COMMON["out_include_dir"],
    out_interface_libs = select({
        "@platforms//os:windows": ["zlib1.lib"],
        "//conditions:default": [],
    }),
    out_shared_libs = select({
        "@platforms//os:macos": [
            "libz.dylib",
            "libz.1.dylib",
        ],
        "@platforms//os:windows": ["zlib1.dll"],
        "//conditions:default": [
            "libz.so",
            "libz.so.1",
        ],
    }),
    postfix_script = select({
        # rfcc pairs DLLs and import libs by basename when it builds CcInfo.
        # zlib installs zlib1.dll with zdll.lib, so add the Windows alias that
        # Bazel consumers actually expect.
        "@platforms//os:windows": (
            "cp -p $$INSTALLDIR/lib/zdll.lib $$INSTALLDIR/lib/zlib1.lib"
        ),
        "//conditions:default": "",
    }),
)

# Public zlib headers providing the plain static-library interface.
cc_library(
    name = "zlib_headers",
    hdrs = ZLIB_PUBLIC_HDRS + [":zlib_configured_zconf_h"],
    includes = [
        ".",
        "generated_include",
    ],
    linkstatic = True,
)

alias(
    name = "zlib_native_headers",
    actual = ":zlib_headers",
)

# Public zlib headers providing the shared-library interface on Windows.
cc_library(
    name = "zlib_dynamic_headers",
    hdrs = ZLIB_PUBLIC_HDRS + [":zlib_configured_zconf_h"],
    defines = select({
        "@platforms//os:windows": ["ZLIB_DLL"],
        "//conditions:default": [],
    }),
    includes = [
        ".",
        "generated_include",
    ],
    linkstatic = True,
)

# Native static zlib library providing the normal Bazel static-library contract.
# The target name is intentionally conventional so Bazel emits a FindZLIB-
# compatible archive name without an extra repackaging layer.
cc_library(
    name = "z",
    srcs = ZLIB_SRCS + ZLIB_PRIVATE_HDRS,
    hdrs = ZLIB_PUBLIC_HDRS,
    copts = ZLIB_NATIVE_COPTS,
    linkstatic = True,
    deps = [":zlib_headers"],
)

# Preserve the descriptive target name for downstream users.
alias(
    name = "zlib_static",
    actual = ":z",
)

# Preserve the existing consumer-facing label for the native static library.
alias(
    name = "zlib_native_static",
    actual = ":zlib_static",
)

# Windows-only native zlib implementation
# providing DLL-exported objects for wrapping.
cc_library(
    name = "zlib_shared_impl",
    srcs = ZLIB_SRCS + ZLIB_PRIVATE_HDRS,
    hdrs = ZLIB_PUBLIC_HDRS,
    copts = ZLIB_NATIVE_COPTS,
    linkstatic = True,
    local_defines = select({
        "@platforms//os:windows": [
            "ZLIB_DLL",
            "ZLIB_INTERNAL",
        ],
        "//conditions:default": [],
    }),
    target_compatible_with = select({
        "@platforms//os:windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    deps = [
        ":zlib_dynamic_headers",
    ],
)

# Bazel-native shared zlib
# providing the cc_shared_library runtime and linker contract.
cc_shared_library(
    name = "zlib_shared",
    features = select({
        # set_install_name is the default for most darwin toolchains, but set
        # it explicitly for documentation purposes for parity with set_soname
        "@platforms//os:macos": ["set_install_name"],
        "@platforms//os:windows": [],
        "//conditions:default": ["set_soname"],
    }),
    shared_lib_name = select({
        "@platforms//os:macos": "libz.dylib",
        "@platforms//os:windows": "zlib1.dll",
        "//conditions:default": "libz.so",
    }),
    deps = select({
        "@platforms//os:windows": [":zlib_shared_impl"],
        "//conditions:default": [":zlib_static"],
    }),
)

alias(
    name = "zlib_native_shared",
    actual = ":zlib_shared",
)

# Windows interface-library bridge
# providing the import lib from cc_shared_library.
filegroup(
    name = "zlib_shared_interface_library",
    srcs = [":zlib_shared"],
    output_group = "interface_library",
    target_compatible_with = select({
        "@platforms//os:windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
)

# Windows shared-library bridge
# providing both the DLL and import lib to cc rules.
cc_import(
    name = "zlib_shared_import",
    interface_library = ":zlib_shared_interface_library",
    shared_library = ":zlib_shared",
    target_compatible_with = select({
        "@platforms//os:windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
)

# Normal cc_library wrapper providing a shared-library dependency with headers.
cc_library(
    name = "zlib_dynamic",
    srcs = select({
        "@platforms//os:windows": [],
        "//conditions:default": [":zlib_shared"],
    }),
    deps = [":zlib_dynamic_headers"] + select({
        "@platforms//os:windows": [":zlib_shared_import"],
        "//conditions:default": [],
    }),
)
