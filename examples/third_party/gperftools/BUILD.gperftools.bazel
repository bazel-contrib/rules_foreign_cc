load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

configure_make(
    name = "gperftools_build",
    configure_options = [
        "--enable-shared=no",
        "--enable-frame-pointers",
        "--disable-libunwind",
    ],
    env = select({
        # This package requires c++17, and bazel 7.x's default BAZEL_CXXOPTS is
        # set to -std=c++14, so override; however, configure_make applies copts
        # to CFLAGS and ASFLAGS too, so use CXXFLAGS directly to avoid adding
        # the c++ standard to autoconf's C-based probes.
        "@platforms//os:macos": {
            "AR": "",
            "CXXFLAGS": "-std=c++17",
        },
        "//conditions:default": {
            "CXXFLAGS": "-std=c++17",
        },
    }),
    lib_source = ":all_srcs",
    out_static_libs = ["libtcmalloc_and_profiler.a"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    targets = [
        # Something is wrong about the project's gtest wiring, resulting in
        # unittests failing to build due to being unable to find gtest.h. They
        # don't provide any official method to bypass building the tests, so
        # work around it by calling the make targets we require directly.
        "install-libLTLIBRARIES",
        "install-perftoolsincludeHEADERS",
        "install-nodist_perftoolsincludeHEADERS",
    ],
    visibility = ["//visibility:public"],
)
