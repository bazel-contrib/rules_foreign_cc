load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

configure_make(
    name = "gperftools_build",
    configure_options = [
        "--enable-shared=no",
        "--enable-frame-pointers",
        "--disable-libunwind",
    ],
    copts = select({
        "@platforms//os:linux": [
            # This package requires c++17, and bazel 7.x's default BAZEL_CXXOPTS is
            # set to -std=c++14, so override.
            "-std=c++17",
        ],
        "//conditions:default": [],
    }),
    env = select({
        "@platforms//os:macos": {"AR": ""},
        "//conditions:default": {},
    }),
    lib_source = ":all_srcs",
    out_static_libs = ["libtcmalloc_and_profiler.a"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    targets = [
        "install-libLTLIBRARIES",
        "install-perftoolsincludeHEADERS",
        "install-nodist_perftoolsincludeHEADERS",
    ],
    visibility = ["//visibility:public"],
)
