load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

configure_make(
    name = "autoconf",
    # Empty `dist_man_MANS` so automake's `all-am` doesn't pull in the
    # `.w.1` suffix rule, which calls `$(HELP2MAN) ... --output=$@.t`
    # followed by `mv $@.t $@`. With HELP2MAN stubbed to `true` (it
    # isn't on RBE workers), the `.t` file is never created and the
    # `mv` fails. Pre-built man pages ship in the tarball and autoconf
    # binaries don't need the regenerated copies at runtime.
    args = ["dist_man_MANS="],
    build_data = [
        "@m4//:m4_exe",
    ],
    env = {
        "M4": "$$EXT_BUILD_ROOT/$(location @m4//:m4_exe)",
        "PERL": "$$EXT_BUILD_ROOT/$(PERL)",
    } | select({
        "@platforms//os:macos": {
            "AR": "",
        },
        "//conditions:default": {},
    }),
    lib_source = ":all_srcs",
    out_binaries = [
        "autoconf",
        "autoheader",
        "autom4te",
        "autoreconf",
        "autoscan",
        "autoupdate",
        "ifnames",
    ],
    out_data_dirs = ["share"],
    out_include_dir = "",
    toolchains = ["@rules_perl//:current_toolchain"],
)

filegroup(
    name = "gen_dir",
    srcs = [":autoconf"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
