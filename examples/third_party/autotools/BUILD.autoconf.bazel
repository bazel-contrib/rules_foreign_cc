load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

configure_make(
    name = "autoconf",
    build_data = [
        "@m4//:m4_exe",
    ],
    env = select({
        "@platforms//os:macos": {
            "AR": "",
            "M4": "$$EXT_BUILD_ROOT/$(location @m4//:m4_exe)",
            "PERL": "$$EXT_BUILD_ROOT/$(PERL)",
        },
        "//conditions:default": {
            "M4": "$$EXT_BUILD_ROOT/$(location @m4//:m4_exe)",
            "PERL": "$$EXT_BUILD_ROOT/$(PERL)",
        },
    }),
    lib_source = ":all_srcs",
    out_binaries = [
        "autoconf",
        "autoheader",
        "autom4te",
        "autoreconf",
        "autoscan",
        "autoupdate",
        "ifnames",
    ],
    out_data_dirs = ["share"],
    toolchains = ["@rules_perl//:current_toolchain"],
)

filegroup(
    name = "gen_dir",
    srcs = [":autoconf"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
