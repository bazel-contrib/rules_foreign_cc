module(
    name = "rules_foreign_cc_examples_third_party",
    version = "0.0.0",
)

bazel_dep(name = "bazel_features", version = "1.28.0")
bazel_dep(name = "bazel_skylib", version = "1.9.0")
bazel_dep(name = "apple_support", version = "1.24.5", repo_name = "build_bazel_apple_support")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "rules_cc", version = "0.2.13")
bazel_dep(name = "rules_apple", version = "3.4.0", repo_name = "build_bazel_rules_apple")
bazel_dep(name = "rules_foreign_cc", version = "0.0.0")
bazel_dep(name = "rules_perl", version = "1.0.0", repo_name = "rules_perl")
bazel_dep(name = "rules_python", version = "1.9.0")
bazel_dep(name = "rules_shell", version = "0.6.1")
bazel_dep(name = "rules_swift", version = "1.17.0", repo_name = "build_bazel_rules_swift")

local_path_override(
    module_name = "rules_foreign_cc",
    path = "../..",
)

tools = use_extension("@rules_foreign_cc//foreign_cc:extensions.bzl", "tools")
use_repo(
    tools,
    "cmake_3.31.8_toolchains",
    "cmake_src",
    "gettext_runtime",
    "glib_dev",
    "glib_src",
    "gnumake_src",
    "meson_src",
    "ninja_1.13.0_toolchains",
    "ninja_build_src",
    "pkgconfig_src",
    "rules_foreign_cc_framework_toolchains",
)

perl = use_extension("@rules_perl//perl:extensions.bzl", "perl_repositories")
use_repo(
    perl,
    "perl_darwin_amd64",
    "perl_darwin_arm64",
    "perl_linux_amd64",
    "perl_linux_arm64",
    "perl_windows_x86_64",
)

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    configure_coverage_tool = True,
    is_default = True,
    python_version = "3.10",
)

pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "third_party_pip",
    python_version = "3.10",
    requirements_lock = "//:requirements_lock.txt",
)
use_repo(pip, "third_party_pip")

third_party = use_extension("//:extensions.bzl", "third_party")
use_repo(
    third_party,
    "apr",
    "apr_util",
    "autoconf",
    "automake",
    "bison",
    "cares",
    "curl",
    "examples_zlib",
    "expat",
    "flex",
    "gettext",
    "gettext_win",
    "glib",
    "gn",
    "gperftools",
    "iconv",
    "iconv_macos",
    "libdrm",
    "libffi",
    "libgit2",
    "libjpeg_turbo",
    "libpciaccess",
    "libpng",
    "libpthread-stubs",
    "libssh2",
    "libtool",
    "libx11",
    "libxau",
    "libxcb",
    "libxdmcp",
    "libxext",
    "libxfixes",
    "libxrandr",
    "libxrender",
    "libxshmfence",
    "log4cxx",
    "m4",
    "mesa",
    "nasm",
    "openssl",
    "pcre",
    "python3",
    "renderproto",
    "sqlite",
    "subversion",
    "winflexbison",
    "xcb-proto",
    "xorgproto",
    "xtrans",
)

register_toolchains(
    "@rules_foreign_cc_framework_toolchains//:all",
    "@cmake_3.31.8_toolchains//:all",
    "@ninja_1.13.0_toolchains//:all",
    "@rules_foreign_cc//toolchains:all",
)
