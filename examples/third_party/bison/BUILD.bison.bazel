load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

# I tested and this builds for me on macOS and Linux, did not check Windows
configure_make(
    name = "bison",
    # On RBE, three regen recipes fire at make time even with the
    # rule's configure-line stubs in place:
    #   * `lib/iconv_open-*.h` from `*.in` via `GPERF` -- generated
    #     Makefile hardcodes `GPERF = gperf` (not `@GPERF@`), so the
    #     configure-line stub doesn't reach it. Override on make line.
    #   * `doc/bison.1` via help2man -- recipe is
    #     `if HELP2MAN --version; then HELP2MAN ... && mv $@.tmp $@; ...`
    #     and `true --version` succeeds, taking the broken branch
    #     (`mv` fails because `true` produces no `.tmp`). Empty
    #     `dist_man_MANS` and `nodist_man_MANS` so `all-am` doesn't
    #     pull the recipe in at all.
    #   * `src/parse-gram.c` regen via the `.y.c` rule, which calls
    #     `tests/bison` (a wrapper around the not-yet-built `src/bison`).
    #     Pre-built `parse-gram.c` ships in the tarball but mtime
    #     parity with `parse-gram.y` triggers the rule. Override
    #     `am__skipyacc=:` so the recipe becomes a no-op (`: $(SHELL)
    #     $(YLWRAP) ...`).
    args = [
        "GPERF=true",
        "am__skipyacc=:",
        "dist_man_MANS=",
        "nodist_man_MANS=",
    ],
    build_data = [
        "@m4//:m4_exe",
    ],
    # See m4 above: NLS recipes need msgfmt, which RBE workers lack.
    configure_options = ["--disable-nls"],
    env = {
        "M4": "$$EXT_BUILD_ROOT/$(location @m4//:m4_exe)",
        "PERL": "$$EXT_BUILD_ROOT/$(PERL)",
    } | select({
        "@platforms//os:macos": {
            "AR": "",
        },
        "//conditions:default": {},
    }),
    lib_source = ":all_srcs",
    out_binaries = [
        "bison",
        "yacc",
    ],
    # Bison depends on m4sugar.m4 in the "share" directory at runtime
    out_data_dirs = ["share"],
    out_include_dir = "",
    out_static_libs = ["liby.a"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    toolchains = ["@rules_perl//:current_toolchain"],
)

filegroup(
    name = "gen_dir",
    srcs = [":bison"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
