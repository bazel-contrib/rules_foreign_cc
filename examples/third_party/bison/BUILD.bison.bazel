load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

# I tested and this builds for me on macOS and Linux, did not check Windows
configure_make(
    name = "bison",
    build_data = [
        "@autoconf//:autoconf_tool",
        "@autoconf//:autoheader_tool",
        "@autoconf//:autom4te_tool",
        "@autoconf//:autoreconf_tool",
        "@autoconf//:gen_dir",
        "@automake//:aclocal_tool",
        "@automake//:automake_tool",
        "@automake//:gen_dir",
        "@m4//:m4_exe",
    ],
    env = {
        "ACLOCAL": "$$EXT_BUILD_ROOT/$(location @automake//:aclocal_tool)",
        "AC_MACRODIR": "$$EXT_BUILD_ROOT/$(location @autoconf//:gen_dir)/share/autoconf",
        "AUTOCONF": "$$EXT_BUILD_ROOT/$(location @autoconf//:autoconf_tool)",
        "AUTOHEADER": "$$EXT_BUILD_ROOT/$(location @autoconf//:autoheader_tool)",
        "AUTOM4TE": "$$EXT_BUILD_ROOT/$(location @autoconf//:autom4te_tool)",
        "AUTOMAKE": "$$EXT_BUILD_ROOT/$(location @automake//:automake_tool)",
        "AUTORECONF": "$$EXT_BUILD_ROOT/$(location @autoconf//:autoreconf_tool)",
        "M4": "$$EXT_BUILD_ROOT/$(location @m4//:m4_exe)",
        "PATH": "$$(dirname $$EXT_BUILD_ROOT/$(location @autoconf//:autoconf_tool)):$$(dirname $$EXT_BUILD_ROOT/$(location @automake//:automake_tool)):$$PATH",
        "PERL": "$$EXT_BUILD_ROOT/$(PERL)",
        "autom4te_perllibdir": "$$EXT_BUILD_ROOT/$(location @autoconf//:gen_dir)/share/autoconf",
    } | select({
        "@platforms//os:macos": {
            "AR": "",
        },
        "//conditions:default": {},
    }),
    lib_source = ":all_srcs",
    out_binaries = [
        "bison",
        "yacc",
    ],
    # Bison depends on m4sugar.m4 in the "share" directory at runtime
    out_data_dirs = ["share"],
    out_static_libs = ["liby.a"],
    target_compatible_with = select({
        "@platforms//os:linux": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    toolchains = ["@rules_perl//:current_toolchain"],
)

filegroup(
    name = "gen_dir",
    srcs = [":bison"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
