load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(
        include = ["**"],
        exclude = ["*.bazel"],
    ),
)

# I tested and this builds for me on macOS and Linux, did not check Windows
configure_make(
    name = "bison",
    # Stub gperf and help2man so make doesn't try to regenerate
    # `lib/iconv_open-*.h` and the man pages -- same shape as m4: the
    # generated Makefile hardcodes `GPERF = gperf` / `HELP2MAN = ...`
    # rather than using `@GPERF@` / `@HELP2MAN@`, so the rule's
    # configure-line stubs don't reach them.
    args = [
        "GPERF=true",
        "HELP2MAN=true",
    ],
    build_data = [
        "@m4//:m4_exe",
    ],
    # See m4 above: NLS recipes need msgfmt, which RBE workers lack.
    configure_options = ["--disable-nls"],
    env = {
        "M4": "$$EXT_BUILD_ROOT/$(location @m4//:m4_exe)",
        "PERL": "$$EXT_BUILD_ROOT/$(PERL)",
    } | select({
        "@platforms//os:macos": {
            "AR": "",
        },
        "//conditions:default": {},
    }),
    lib_source = ":all_srcs",
    out_binaries = [
        "bison",
        "yacc",
    ],
    # Bison depends on m4sugar.m4 in the "share" directory at runtime
    out_data_dirs = ["share"],
    out_include_dir = "",
    out_static_libs = ["liby.a"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    toolchains = ["@rules_perl//:current_toolchain"],
)

filegroup(
    name = "gen_dir",
    srcs = [":bison"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
