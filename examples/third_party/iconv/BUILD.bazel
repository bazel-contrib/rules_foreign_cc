load("@bazel_skylib//rules:build_test.bzl", "build_test")

exports_files(
    [
        "BUILD.iconv.bazel",
    ],
    visibility = ["//visibility:public"],
)

build_test(
    name = "iconv_build_test",
    target_compatible_with = select({
        "@platforms//os:linux": [],
        "@platforms//os:macos": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    targets = [":iconv_build_target"],
    visibility = ["//:__pkg__"],
)

alias(
    name = "iconv_build_target",
    actual = select({
        "@platforms//os:macos": "@iconv_macos//:iconv",
        "//conditions:default": "@iconv//:iconv",
    }),
)

test_suite(
    name = "all_tests",
)
