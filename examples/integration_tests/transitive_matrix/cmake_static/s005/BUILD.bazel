load(
    "//integration_tests/transitive_matrix:consumer_tests.bzl",
    "cmake_cache_entries",
    "cmake_consumer_test",
    "expected_linkage",
)

# foreign_cc cmake static deps
# app: cmake()
# libarchive: foreign_cc static
# zlib: native static
cmake_consumer_test(
    name = "t",
    cache_entries = cmake_cache_entries(
        libarchive = "archive",
        zlib = "z",
    ),
    expected_linkage = expected_linkage(
        app_static_deps = [
            "libarchive",
            "zlib",
        ],
    ),
    deps = [
        "@examples_libarchive//:libarchive_foreign_static_zlib_static",
        "@examples_zlib//:zlib_static",
    ],
)

test_suite(
    name = "linkage_tests",
    tests = [":t_linkage_test"],
    visibility = ["//integration_tests/transitive_matrix/cmake_static:__pkg__"],
)

test_suite(
    name = "tests",
    tests = [
        ":linkage_tests",
    ],
    visibility = ["//integration_tests/transitive_matrix/cmake_static:__pkg__"],
)
