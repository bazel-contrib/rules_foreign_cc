load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake", "configure_make", "make", "meson", "ninja")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load(":runtime_search_paths_tests.bzl", "runtime_search_paths_test")

UNIX_ONLY = select({
    "@platforms//os:linux": [],
    "@platforms//os:macos": [],
    "//conditions:default": ["@platforms//:incompatible"],
})

LEAF_SHARED_LIB = select({
    "@platforms//os:macos": ["libleaf.dylib"],
    "//conditions:default": ["libleaf.so"],
})

MIDDLE_SHARED_LIB = select({
    "@platforms//os:macos": ["libmiddle.dylib"],
    "//conditions:default": ["libmiddle.so"],
})

MAKE_SHARED_LIBRARY_ARGS = select({
    "@platforms//os:macos": [
        "SHARED_LIBRARY_SUFFIX=dylib",
        "SHARED_LIBRARY_LINK_FLAG=-dynamiclib",
        "LEAF_INSTALL_NAME=-Wl,-install_name,@rpath/libleaf.dylib",
        "MIDDLE_INSTALL_NAME=-Wl,-install_name,@rpath/libmiddle.dylib",
    ],
    "//conditions:default": [
        "SHARED_LIBRARY_SUFFIX=so",
        "SHARED_LIBRARY_LINK_FLAG=-shared",
    ],
})

NINJA_LEAF_TARGETS = select({
    "@platforms//os:macos": [
        "leaf-dylib",
        "install-leaf-dylib",
    ],
    "//conditions:default": [
        "leaf-so",
        "install-leaf-so",
    ],
})

NINJA_MIDDLE_TARGETS = select({
    "@platforms//os:macos": [
        "middle-dylib",
        "install-middle-dylib",
    ],
    "//conditions:default": [
        "middle-so",
        "install-middle-so",
    ],
})

NINJA_APP_TARGETS = select({
    "@platforms//os:macos": [
        "app-dylib",
        "install-app-dylib",
    ],
    "//conditions:default": [
        "app-so",
        "install-app-so",
    ],
})

NINJA_APP_BUNDLE_TARGETS = select({
    "@platforms//os:macos": [
        "app-dylib",
        "install-leaf-dylib",
        "install-middle-dylib",
        "install-app-dylib",
    ],
    "//conditions:default": [
        "app-so",
        "install-leaf-so",
        "install-middle-so",
        "install-app-so",
    ],
})

filegroup(
    name = "srcs",
    srcs = glob(
        ["**"],
        exclude = [
            "BUILD.bazel",
            "runtime_search_paths_tests.bzl",
            "runtime_search_paths_test.sh",
            "runtime_search_test.sh",
        ],
    ),
)

cmake(
    name = "cmake_leaf",
    cache_entries = {
        "RUNTIME_CHAIN_COMPONENT": "leaf",
        "RUNTIME_TEST_FAMILY": "cmake",
    },
    lib_source = ":srcs",
    out_include_dir = "",
    out_shared_libs = LEAF_SHARED_LIB,
    runtime_library_search_directories = "enabled",
    target_compatible_with = UNIX_ONLY,
)

cmake(
    name = "cmake_middle",
    cache_entries = {
        "RUNTIME_CHAIN_COMPONENT": "middle",
        "RUNTIME_TEST_FAMILY": "cmake",
    },
    lib_source = ":srcs",
    out_include_dir = "",
    out_shared_libs = MIDDLE_SHARED_LIB,
    runtime_library_search_directories = "enabled",
    target_compatible_with = UNIX_ONLY,
    deps = [":cmake_leaf"],
)

cmake(
    name = "cmake_app",
    cache_entries = {
        "RUNTIME_CHAIN_COMPONENT": "app",
        "RUNTIME_TEST_FAMILY": "cmake",
    },
    lib_source = ":srcs",
    out_binaries = ["runtime_app"],
    out_include_dir = "",
    runtime_library_search_directories = "enabled",
    target_compatible_with = UNIX_ONLY,
    deps = [":cmake_middle"],
)

cmake(
    name = "cmake_app_bundle",
    cache_entries = {
        "RUNTIME_CHAIN_COMPONENT": "bundle",
        "RUNTIME_TEST_FAMILY": "cmake_app_bundle",
    },
    lib_source = ":srcs",
    out_binaries = ["runtime_app"],
    out_include_dir = "",
    out_shared_libs = LEAF_SHARED_LIB + MIDDLE_SHARED_LIB,
    runtime_library_search_directories = "enabled",
    target_compatible_with = UNIX_ONLY,
)

sh_test(
    name = "cmake_test",
    size = "small",
    srcs = ["runtime_search_test.sh"],
    args = [
        "cmake",
        "$(rlocationpath :cmake_app)",
    ],
    data = [
        ":cmake_app",
        "@bazel_tools//tools/bash/runfiles",
    ],
    target_compatible_with = UNIX_ONLY,
)

sh_test(
    name = "cmake_app_bundle_test",
    size = "small",
    srcs = ["runtime_search_test.sh"],
    args = [
